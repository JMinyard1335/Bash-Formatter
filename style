#!/usr/bin/env bash
#
# used to format output.
# Standard output functions
#	format error <message>
#	format warn <message>
#	format ok <message>
#	format log <tag> <message>
#	format logln <tag> <message>
#
# Help menu formatting
#	format title <text>
#	format header <text>
#	format option [opts] <flags> <description>
#	format example <tool> <opts> <args>


## Source the required paths.
SCRIPT_PATH="$(realpath -- "$0")"
SCRIPT_DIR="$(dirname -- "$SCRIPT_PATH")"
SCRIPT_NAME="$(basename -- "$0")"

if [[ -d "$SCRIPT_DIR/lib" ]]; then
    LIB_DIR="$SCRIPT_DIR/lib"
elif [[ -d "$HOME/.local/lib/$SCRIPT_NAME" ]]; then
    LIB_DIR="$HOME/.local/lib/$SCRIPT_NAME"
elif [[ -d "/usr/lib/$SCRIPT_NAME" ]]; then
    LIB_DIR="/usr/lib/$SCRIPT_NAME"
else
    printf '[Error]: Could not locate library directory for %s\n' "$SCRIPT_NAME" >&2
    exit 1
fi

source "$LIB_DIR/help_menu.sh"
source "$LIB_DIR/format_output.sh"
## -------------------------

_format_usage() {
    cat <<EOF
Usage:
  format <command> [args...]

Commands:
  install remove update version
  error warn ok log logln
  title header option example
EOF
}

# Makes sure the first arg given is a valid cmd
_format_valid_cmd() {
    case "$1" in
        help|'')
            _format_usage
            exit 0
            ;;
	version) logln "format" "0.0.1"; exit 0;;
        install|remove|update|\
        error|warn|ok|log|logln|\
        title|header|option|example)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# _formatter_handle_install <cmd>
_formatter_handle_install() {

    # Ensure the bash installer is installed to the system
    which_installer=$(which installer)
    if [[ -z "$which_installer" ]]; then
	temp_dir=""
	installer_repo="https://github.com/JMinyard1335/Bash-Installer"
	logln "Installer not found on system installing now."

	# create a temp dir
	temp_dir="$(mktemp -d)" || {
            error "Failed to create temporary directory"
            exit 1
        }

	# attempt to clone
	git clone "$installer_repo" "$temp_dir" || {
            error "Failed to clone installer repository"
            rm -rf -- "$temp_dir"
            exit 1
        }
	
	"$temp_dir/installer" install "$temp_dir" || {
            error "Failed to install installer"
            rm -rf -- "$temp_dir"
            exit 1
        }

	rm -rf -- "$temp_dir"

	which_installer="$(command -v installer)"
        [[ -z "$which_installer" ]] && {
            error "Installer still not found after installation"
            exit 1
        }
    fi

    case "$cmd" in
	install) installer install "$SCRIPT_DIR";;
	update) installer update "$SCRIPT_NAME";;
	remove) installer remove "$SCRIPT_NAME";;
    esac
}

# Dispatch to the matching sourced function.
_formatter_parse_args() {
    local cmd="${1:-}"

    # make sure command is valid
    if ! _format_valid_cmd "$cmd"; then
        error "Invalid command was given"
        _format_usage
        exit 1
    fi
    shift	# we have the command shift the argument line.

    # if the user wants to run the installer make sure it is on the system first.
    if [[ "$cmd" == "install" || "$cmd" == "update" || "$cmd" == "remove" ]]; then
	_formatter_handle_install "$cmd"
    else
	"$cmd" "$@"
    fi

}

_formatter_parse_args "$@"
